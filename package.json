{
  "name": "openclaw-setup",
  "version": "0.1.0",
  "description": "OpenClaw 安装/配置助手 — 帮助用户快速安装与配置 OpenClaw",
  "main": "dist/main/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "build:renderer": "vite build --config src/renderer/vite.config.ts",
    "build": "npm run build:renderer && tsc",
    "start": "npm run build:renderer && tsc && electron .",
    "dev": "npm run build:renderer && tsc && electron .",
    "dev:renderer": "vite --config src/renderer/vite.config.ts",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^4.5.2",
    "electron": "^28.3.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0"
  },
  "build": {
    "appId": "com.openclaw.setup",
    "productName": "OpenClaw 安装助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.57.0",
    "dompurify": "^3.3.3",
    "electron-ollama": "^0.1.25",
    "marked": "^17.0.4"
  }
}
